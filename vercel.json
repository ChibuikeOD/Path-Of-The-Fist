{
  "name": "path-of-the-fist",
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/chat/stream",
      "dest": "https://path-of-the-fist.onrender.com/chat/stream"
    },
    {
      "src": "/chat",
      "dest": "https://path-of-the-fist.onrender.com/chat"
    },
    {
      "src": "/events/(.*)",
      "dest": "https://path-of-the-fist.onrender.com/events/$1"
    },
    {
      "src": "/players/(.*)",
      "dest": "https://path-of-the-fist.onrender.com/players/$1"
    },
    {
      "src": "/characters/(.*)",
      "dest": "https://path-of-the-fist.onrender.com/characters/$1"
    },
    {
      "src": "/sets/(.*)",
      "dest": "https://path-of-the-fist.onrender.com/sets/$1"
    },
    {
      "src": "/health",
      "dest": "https://path-of-the-fist.onrender.com/health"
    },
    {
      "src": "/sync/(.*)",
      "dest": "https://path-of-the-fist.onrender.com/sync/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "frontend/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/$1"
    }
  ]
}
